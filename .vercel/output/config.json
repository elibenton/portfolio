{
	"version": 3,
	"routes": [
		{
			"src": "/_app/immutable/.+",
			"headers": {
				"cache-control": "public, immutable, max-age=31536000"
			}
		},
		{
			"handle": "filesystem"
		},
		{
			"src": "/.*",
			"dest": "/fn"
		}
	],
	"overrides": {},
	"images": {
		"sizes": [
			640,
			828,
			1200,
			1920
		],
		"formats": [
			"image/avif",
			"image/webp"
		],
		"minimumCacheTTL": 300
	}
}